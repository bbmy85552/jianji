{
  "name": "jianji",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "npm --prefix server run dev",
    "build": "npm --prefix server run build && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "npm --prefix server run test",
    "setup": "npm install && npm --prefix server install && npm --prefix server run prisma:generate && npm --prefix server run prisma:migrate",
    "deploy": "bash scripts/install.sh",
    "docs-platform": "node scripts/docs-platform-cli.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@tiptap/extension-character-count": "^2.27.2",
    "@tiptap/extension-color": "^2.10.3",
    "@tiptap/extension-highlight": "^2.10.3",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.10.3",
    "@tiptap/extension-subscript": "^2.27.2",
    "@tiptap/extension-superscript": "^2.27.2",
    "@tiptap/extension-table": "^2.10.3",
    "@tiptap/extension-table-cell": "^2.10.3",
    "@tiptap/extension-table-header": "^2.10.3",
    "@tiptap/extension-table-row": "^2.10.3",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/extension-text-align": "^2.10.3",
    "@tiptap/extension-text-style": "^2.10.3",
    "@tiptap/extension-underline": "^2.10.3",
    "@tiptap/pm": "^2.10.3",
    "@tiptap/react": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "@types/papaparse": "^5.5.2",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.7.9",
    "lucide-react": "^0.546.0",
    "papaparse": "^5.5.3",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.1.1",
    "vite": "^6.2.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
