# ----- 基础 -----
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000

# ----- 数据库（默认 SQLite，无需额外服务） -----
DATABASE_URL="file:./prisma/dev.db"

# ----- 鉴权 -----
# 生产环境必须改成至少 32 位随机值，且绑定邮箱后不要更换。
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d
COOKIE_NAME=jianji_session
COOKIE_SECURE=false
SETUP_TOKEN=replace-with-at-least-32-random-characters

# ----- 默认管理员（开发环境兜底种子账号） -----
# 生产环境 Docker 首次部署会通过网页初始化创建管理员，不再建议在 .env 中写入管理员密码。
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_NAME=管理员

# ----- 邮件 SMTP（可选兜底；推荐在网页初始化页面中配置） -----
MAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=
MAIL_PASS=
MAIL_FROM="文档中心 <no-reply@example.com>"

# ----- Google 登录（可选） -----
# 前端通过 /api/public/settings 读取该值；后端用同一个 Client ID 校验 Google ID token。
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ----- 验证码 / 防刷阈值（PRD §7.9 默认值） -----
CODE_TTL_SECONDS=600
CODE_RESEND_INTERVAL_SECONDS=60
CODE_MAX_PER_HOUR_PER_EMAIL=5
CODE_MAX_PER_HOUR_PER_IP=20
CODE_MAX_PER_DAY_PER_EMAIL=20
CODE_MAX_ATTEMPTS=5

# ----- 注册策略 -----
ALLOW_PUBLIC_REGISTER=true

# ----- 版本与更新（可选） -----
APP_VERSION=0.1.0
JIANJI_LATEST_VERSION=
JIANJI_CURRENT_COMMIT=
JIANJI_UPDATE_REPO=https://github.com/staklab/jianji.git
JIANJI_UPDATE_BRANCH=main
# 默认检查 main 分支最新提交，也可换成返回 {"version":"0.2.0"} 或 {"sha":"..."} 的自定义地址。
JIANJI_UPDATE_CHECK_URL=https://api.github.com/repos/staklab/jianji/commits/main
# 非 Git checkout 部署会从分支归档刷新源码；直连 GitHub 不通时可设置为可信镜像/反代地址。
JIANJI_UPDATE_ARCHIVE_URL=
# 生产环境需要后台按钮自动执行更新时，可配置为 bash /opt/jianji/scripts/update.sh
JIANJI_UPDATE_COMMAND=

# ----- 邮箱聚合（M3） -----
# IMAP/SMTP 凭据由 JWT_SECRET 派生的 AES-256-GCM 密钥加密后存入数据库。
# 此处无需额外配置；只需保证 JWT_SECRET 不要换（否则历史绑定将失效）。
